# Copy this file to .env and fill in the keys you have.
# Any key left blank just means that module gets skipped at runtime.
MILOSINT_SHODAN_API_KEY=
MILOSINT_CENSYS_API_ID=
MILOSINT_CENSYS_API_SECRET=
MILOSINT_OTX_API_KEY=
MILOSINT_VIRUSTOTAL_API_KEY=
MILOSINT_GRAYHATWARFARE_API_KEY=
MILOSINT_GITHUB_TOKEN=
MILOSINT_LEAKIX_API_KEY=
MILOSINT_THREATFOX_API_KEY=
MILOSINT_ZOOMEYE_API_KEY=
MILOSINT_NETLAS_API_KEY=
MILOSINT_VULNERS_API_KEY=
MILOSINT_BREACHDIRECTORY_API_KEY=
MILOSINT_ONYPHE_API_KEY=
MILOSINT_CRIMINAL_IP_API_KEY=
MILOSINT_HIBP_API_KEY=
MILOSINT_INTELX_API_KEY=
MILOSINT_DEHASHED_EMAIL=
MILOSINT_DEHASHED_API_KEY=
MILOSINT_SECURITYTRAILS_API_KEY=
MILOSINT_NVD_API_KEY=
MILOSINT_URLSCAN_API_KEY=
# Session cookie from a logged-in urlscan.io browser session, NOT your
# password -- see CONFIG comment for urlscan_session_cookie in
# military_osint_tool_v2.py for how to export it. Optional; the module
# works off the free /search/ endpoint without it.
MILOSINT_URLSCAN_SESSION_COOKIE=
MILOSINT_TAVILY_API_KEY=

# AI inference layer (all optional — tried in this order: Groq, Gemini,
# OpenRouter, then Ollama last. See CONFIG comment for groq_api_key/
# ollama_url in military_osint_tool_v2.py for quota/performance details).
MILOSINT_GROQ_API_KEY=
MILOSINT_GEMINI_API_KEY=
MILOSINT_OPENROUTER_API_KEY=
MILOSINT_OLLAMA_URL=

# whatsapp_bot.py (optional — only needed if you use the WhatsApp interface)
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_YOUR_NUMBER=
WHATSAPP_NGROK_AUTHTOKEN=
