# Real API keys — never commit these. Use .env.example as the template.
.env

# Python
__pycache__/
*.pyc

# Ever-growing runtime log — diagnostic noise, not analytical data
osint_tool_v2.log

# Per-run byproducts -- superseded by military_osint_master.csv every run,
# so keeping them around (and in git) is just redundant clutter.
MilOSINT_v2_Task_*.xml
military_osint_data_v2_*.csv
military_osint_stix_v2_*.json
weekly_delta_v2_*.txt

# Local Claude Code session config, not part of the project
.claude/

# Local-only safety backups and manual run logs — never push these; a backup
# of the pre-filter dataset would put "removed" countries' data right back
# into the public repo under a different filename.
military_osint_master_*BACKUP*.csv
run*_narrowed_*.log
run[0-9]_*.log
